# vim:filetype=toml

#window-width = 180
#window-height = 65
cursor-style = "block"
cursor-style-blink = true
font-family = "FiraCode Nerd Font"
font-size = 15
font-thicken
macos-option-as-alt = left
macos-option-as-alt = true
macos-titlebar-style = "tabs"
mouse-hide-while-typing = true
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s
quick-terminal-animation-duration = 0.05
quick-terminal-position = "center"
quick-terminal-size = "1800px,500px"
shell-integration-features = "no-cursor"
split-divider-color = "#888888"
theme = Arthur
theme = Monokai Remastered
theme = Monokai Pro
theme = Monokai Pro Spectrum
theme = "tokyonight"
unfocused-split-opacity = 0.80
window-position-x = 1000
window-position-y = 500
window-theme = "system"
confirm-close-surface = false
copy-on-select = clipboard
window-step-resize = true
window-decoration = auto

keybind = "alt+j=next_tab"
keybind = "alt+k=previous_tab"
keybind = "alt+shift+j=move_tab:+1"
keybind = "alt+shift+k=move_tab:-1"
keybind = "global:alt+backquote=toggle_quick_terminal"
keybind = "alt+,>y=write_scrollback_file:copy"
keybind = "alt+,>,=prompt_surface_title"
keybind = "alt+,>l=new_split:right"
keybind = "alt+,>d=new_split:down"
keybind = "alt+,>u=new_split:up"
keybind = "alt+,>r=new_split:right"
keybind = "cmd+;=goto_split:next"
keybind = "cmd+z=toggle_split_zoom"
keybind = "alt+p=scroll_page_lines:-3"
keybind = "alt+n=scroll_page_lines:+3"
keybind = "alt+shift+p=scroll_page_up"
keybind = "alt+shift+n=scroll_page_down"

keybind = shift+enter=text:\x1b\r
keybind = "ctrl+[=text:\x1b"
