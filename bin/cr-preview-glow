#!/usr/bin/env bash
# Markdown-rendered session preview for `cr`, via glow. $1 = session jsonl file.
# Hybrid: a compact metadata header, then the last 50 filtered messages (user
# prompts + assistant replies) in reverse-chron order, rendered as markdown.
# thinking/tool blocks dropped. Width from fzf's $FZF_PREVIEW_COLUMNS.
jq -rs "$(
	cat <<'EOF'
(map(.sessionId  // empty)              | last) as $id     |
(map(.customTitle // empty)             | last) as $custom |
(map(select(.type=="ai-title").aiTitle) | last) as $ai     |
# launch dir = the recorded cwd whose '/'->'-' encoding matches the project
# folder; only that dir is a valid 'claude --resume' target. fall back to first.
(input_filename | split("/") | .[-2]) as $folder |
((map(.cwd // empty) | map(select(gsub("/";"-") == $folder)) | first)
 // (map(.cwd // empty) | first)) as $cwd |
($cwd | if startswith(env.HOME + "/") then "~" + .[(env.HOME|length):]
        elif . == env.HOME then "~" else . end) as $dir |
(map(.gitBranch // empty)               | last) as $branch |
([.[]|select(.type=="user")]     | length) as $nin  |
([.[]|select(.type=="assistant")]| length) as $nout |
([.[]|.timestamp // empty] | last) as $ts |
(try (($ts|sub("\\.[0-9]+Z$";"Z")|fromdateiso8601)) catch null) as $t |
(if $t == null then "?"
 else ((now - $t)/60) | if . < 60 then "\(.|floor)m ago"
   elif . < 1440 then "\((./60)|floor)h ago"
   else "\((./1440)|floor)d ago" end end) as $age |
# chronological [{role,text}], dropping wrappers/thinking/tool/empty messages
[ .[]
  | if .type=="user" then
      ( .message.content
        | select(type=="string") | select(startswith("<")|not)
        | {role:"### 🧑 You", text:.} )
    elif .type=="assistant" then
      ( [.message.content[]? | select(.type=="text") | .text]
        | join("\n\n") | select(length > 0)
        | {role:"### 🤖 Claude", text:.} )
    else empty end
] as $msgs |
($msgs[-50:] | reverse) as $recent |
"# \($custom // $ai // "(untitled)")",
"",
"`\($dir)` · \($branch // "-") · \($age)",
"",
"**id** `\($id)` · **msgs** \($nin) in / \($nout) out",
"",
"---",
"",
($recent[] | .role, "", .text, "")
EOF
)" "$1" | CLICOLOR_FORCE=1 glow -s dark -w "${FZF_PREVIEW_COLUMNS:-80}" -
