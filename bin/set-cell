#!/usr/bin/env bash

set -euo pipefail

ENVRC=~/code/temporal/.envrc
PRELUDE="export CELL="

usage() {
	echo >&2 -e "$(basename "$0") sets the current CELL env var\n"
	echo >&2 "usage: $(basename "$0") [cell]"
	exit 1
}

die() {
	echo >&2 -e "fatal: $*"
	exit 1
}

[[ $# -eq 1 ]] || usage
[[ -z "$1" ]] || [[ "$1" =~ [[:space:]] ]] && die "malformed cell"
[[ -f $ENVRC ]] || die "$ENVRC not found"

sed -i -E "s/^$PRELUDE.*/$PRELUDE$1/" $ENVRC
grep "^$PRELUDE$1$" $ENVRC &>/dev/null || die "setting failed"
cd ~/code/temporal && direnv allow
