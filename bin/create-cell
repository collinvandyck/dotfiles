#!/usr/bin/env bash
set -euo pipefail

CELL="s-cds-collin-$(date +%y%m%d)"
TEMPLATE=v5-aws-small
CLOUD_PROVIDER=""
DRY_RUN=""

usage() {
	echo -e "usage: $(basename "$0") --cell [CELL] --template [TEMPLATE] [--cloud-provider aws|gcp] [--dry-run]" >&2
	exit 1
}

die() {
	echo -e "$@" >&2
	usage
}

run() {
	echo "$@"
	[[ -n "$DRY_RUN" ]] && return 0
	"$@"
}

while [[ $# -gt 0 ]]; do
	case "$1" in
	--cell | -c)
		CELL=$2
		shift 2
		;;
	--cell=*)
		CELL="${1#*=}"
		shift
		;;
	--template | -t)
		TEMPLATE=$2
		shift 2
		;;
	--template=*)
		TEMPLATE="${1#*=}"
		shift
		;;
	--cloud-provider | -p)
		CLOUD_PROVIDER=$2
		shift 2
		;;
	--cloud-provider=*)
		CLOUD_PROVIDER="${1#*=}"
		shift
		;;
	--dry-run | -n)
		DRY_RUN=1
		shift
		;;
	**)
		usage
		;;
	esac
done

[[ -z "$CELL" ]] && die "cell required"
[[ -z "$TEMPLATE" ]] && die "template required"

# omni's cloud provider defaults to aws regardless of the template name, so a
# gcp template lands on aws infra unless we say otherwise. Infer the provider
# from the template (v5-<provider>-*) when it wasn't set explicitly.
if [[ -z "$CLOUD_PROVIDER" ]]; then
	case "$TEMPLATE" in
	*gcp*) CLOUD_PROVIDER=gcp ;;
	*aws*) CLOUD_PROVIDER=aws ;;
	*) ;;
	esac
fi

args=(--cell-id "$CELL" --benchgo-enabled --namespace "$CELL-marathon" --yaml "$TEMPLATE")
[[ -n "$CLOUD_PROVIDER" ]] && args+=(--cloud-provider "$CLOUD_PROVIDER")

run omni scaffold environment create "${args[@]}"
