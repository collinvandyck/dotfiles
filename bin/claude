#!/usr/bin/env bash
set -euo pipefail

# sets up the standard operating environment for claude.
# explicitly a bash script to avoid inheriting aliases for things like lsd.

# use bash for claude code sessions
export CLAUDE_CODE_SHELL=bash
export CLAUDE=~/.local/bin/claude
export CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD=1

[[ ! -e "${CLAUDE:-}" ]] && {
	echo "Installing claude..."
	curl -fsSL https://claude.ai/install.sh | bash
}

args=()
mixins=(~/code/temporal)

if [[ $# == 0 ]] || ! [[ "$1" =~ ^(agents|auth|auto-mode|doctor|install|mcp|plugin|plugins|project|setup-token|ultrareview|update|upgrade|-h|--help)$ ]]; then
	for mixin in "${mixins[@]}"; do
		if [[ -d "$mixin" ]]; then
			args+=("--add-dir" "$mixin")
		fi
	done
fi

exec $CLAUDE "${args[@]}" "$@"
